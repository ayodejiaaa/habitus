datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  CLIENT
  ADMIN
}

enum RequestStage {
  FOUNDATION
  STRUCTURE
  ROOFING
  FINISHING
  OTHER
}

enum RequestStatus {
  PENDING_PAYMENT
  PAYMENT_VERIFIED
  INSPECTION_SCHEDULED
  IN_PROGRESS
  COMPLETED
  ISSUED
}

enum AssessmentStatus {
  ON_TRACK
  NEEDS_ATTENTION
  ISSUE_DETECTED
}

enum RecommendationStatus {
  PROCEED
  PROCEED_WITH_CAUTION
  PAUSE_FUNDING
}

enum AssetType {
  PHOTO
  VIDEO
}

enum StorageProvider {
  GOOGLE_DRIVE
  YOUTUBE
  VIMEO
  S3
  R2
}

enum MediaType {
  IMAGE
  VIDEO
}

enum ReportStatus {
  DRAFT
  ISSUED
}

model User {
  id                  String               @id @default(cuid())
  name                String?
  email               String               @unique
  password            String?              // Hashed password for credentials provider
  role                UserRole             @default(CLIENT)
  emailVerified       DateTime?
  image               String?
  emailAuditReports   Boolean              @default(true)
  statusChangeAlerts  Boolean              @default(true)
  passwordVersion     Int                  @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  requests            InspectionRequest[]
  passwordResetTokens PasswordResetToken[]
  verificationTokens  VerificationToken[]
}

model InspectionRequest {
  id                  String             @id @default(cuid())
  userId              String
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectName         String
  propertyAddress     String
  city                String
  state               String
  country             String
  propertyType        String             // "Residential" | "Commercial" | "Other"
  stage               RequestStage
  serviceId           String
  service             InspectionService  @relation(fields: [serviceId], references: [id])
  siteContactName     String
  siteContactPhone    String
  notes               String?
  specialInstructions String?
  status              RequestStatus      @default(PENDING_PAYMENT)
  paymentStatus       String             @default("UNPAID")
  paystackReference   String?            @unique
  paystackAuthUrl     String?
  paymentProvider     String?            @default("PAYSTACK")
  paymentEnvironment   String?            @default("test")
  paidAt              DateTime?
  verifiedAt          DateTime?
  verificationResponse Json?
  webhookProcessed    Boolean            @default(false)
  webhookProcessedAt  DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  reports             InspectionReport[]
}

model InspectionReport {
  id                String             @id @default(cuid())
  requestId         String             @unique
  request           InspectionRequest  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  assessmentStatus  AssessmentStatus
  executiveSummary  String
  findings          String             // Stored as a newline-separated string
  recommendation    RecommendationStatus
  status            ReportStatus       @default(DRAFT)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  mediaAssets       MediaAsset[]
}

model MediaAsset {
  id                String            @id @default(cuid())
  reportId          String
  report            InspectionReport  @relation(fields: [reportId], references: [id], onDelete: Cascade)
  storageProvider   StorageProvider
  originalFileName  String?
  displayName       String?
  mediaType         MediaType
  trustedUrl        String
  uploadedBy        String?
  uploadedAt        DateTime          @default(now())
  checksum          String?
}

model InspectionService {
  id           String              @id @default(cuid())
  name         String
  slug         String              @unique
  description  String
  price        Float
  isActive     Boolean             @default(false)
  displayOrder Int                 @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  requests     InspectionRequest[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model VerificationToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model RateLimit {
  key       String   @id
  points    Int      @default(0)
  expiresAt DateTime
}
